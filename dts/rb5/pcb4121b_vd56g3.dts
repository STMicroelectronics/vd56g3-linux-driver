/dts-v1/;
/plugin/;

/ {

	fragment@0 {
		target = <&camcc>;
		__overlay__ {
			status = "okay";
		};
	};

	fragment@1 {
		target = <&camss>;
		__overlay__ {
			status = "okay";

			ports {
				/* The port index denotes CSI PHY -> here CSI0 */
				port@0 {
					reg = <0x0>;
					csiphy0_ep: endpoint {
						clock-lanes = <2>;
						data-lanes = <0 1>;
						remote-endpoint = <&vd56g3_ep>;
					};
				};
			};
		};
	};

	fragment@2 {
		target = <&soc>;
		__overlay__ {
			camera_clk_12M: camera_clk_12M {
				#clock-cells = <0>;
				compatible = "fixed-clock";
				clock-frequency = <12000000>;
			};

			v1v2: v1v2@0 {
				compatible = "regulator-fixed";
				regulator-name = "fixed-supply-1v2";
				regulator-min-microvolt = <1200000>;
				regulator-max-microvolt = <1200000>;
				/* we connect spider 3v3 to 2v8 throught stmipi */
				/*vin-supply = <&v2v8>;*/
			};

			v1v8: v1v8@0 {
				compatible = "regulator-fixed";
				regulator-name = "fixed-supply-1v8";
				regulator-min-microvolt = <1800000>;
				regulator-max-microvolt = <1800000>;
				/* we connect spider 3v3 to 2v8 throught stmipi */
				/*vin-supply = <&v2v8>;*/
			};

			v2v8: v2v8@0 {
				compatible = "regulator-fixed";
				regulator-name = "fixed-supply-2v8";
				regulator-min-microvolt = <2800000>;
				regulator-max-microvolt = <2800000>;
				/* we connect spider 3v3 to 2v8 throught stmipi */
				/*vin-supply = <&v2v8>;*/
			};
		};
	};

	fragment@3 {
		target = <&i2c4>;
		__overlay__ {
			#address-cells = <1>;
			#size-cells = <0>;
			cam0: cam0@10 {
				status = "ok";
				compatible = "st,st-vd56g3";
				reg = <0x10>;
				clocks = <&camera_clk_12M>;
				clock-names = "xclk";
				vcore-supply = <&v1v2>;
				vddio-supply = <&v1v8>;
				vana-supply = <&v2v8>;
				reset-gpios = <&tlmm 93 1>;
				port {
					vd56g3_ep: endpoint {
						clock-lanes = <0>;
						data-lanes = <1 2>;
						link-frequencies =
							/bits/ 64 <402000000>;
						remote-endpoint = <&csiphy0_ep>;
					};
				};
			};
		};
	};

};
