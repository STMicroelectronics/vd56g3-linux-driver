#!/usr/bin/make -f

include /usr/share/dpkg/pkg-info.mk

%:
	dh $@ --with dkms

override_dh_install:
	dh_install src/Makefile usr/src/vd56g3-$(DEB_VERSION_UPSTREAM)/
	dh_install dts usr/src/vd56g3-$(DEB_VERSION_UPSTREAM)/
	dh_install src/Kbuild usr/src/vd56g3-$(DEB_VERSION_UPSTREAM)/
	dh_install src/*.c usr/src/vd56g3-$(DEB_VERSION_UPSTREAM)/

override_dh_dkms:
	dh_dkms -V $(DEB_VERSION_UPSTREAM)

override_dh_auto_configure:
override_dh_auto_build:
override_dh_auto_test:
override_dh_auto_install:
override_dh_auto_clean:
